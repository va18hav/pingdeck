generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id          String     @id @default(uuid())
  name        String
  description String?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  endpoints   Endpoint[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Endpoint {
  id           String     @id @default(uuid())
  name         String
  url          String
  method       String     @default("GET")
  interval     Int
  status       String     @default("PENDING")
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  repeatJobKey String?
  responses    Response[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Response {
  id           String   @id @default(uuid())
  endpoint     Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  endpointId   String
  statusCode   Int?
  responseTime Int?
  status       String // 'UP' | 'DOWN'
  error        String?
  createdAt    DateTime @default(now())
}

model Worker {
  id         String       @id
  hostName   String
  startedAt  DateTime
  lastSeenAt DateTime
  status     WorkerStatus
}

enum WorkerStatus {
  RUNNING
  DEAD
  OFFLINE
}
